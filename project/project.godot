; Engine configuration file
; This file is automatically generated by Godot.
; It is best not to edit it manually, but if you must,
; try to keep the changes minimal and well documented.
; If you make a mistake, you may not be able to open your project.

[application]

config/name="Neftegorsk"
config/icon="res://assets/icons/app_icon.svg"
run/main_scene="res://scenes/main_menu/main_menu.tscn"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/resizable=true
window/mode/window_mode=0
window/vsync/vsync_mode=1

[rendering]

rendering_method/renderer="forward_plus"
rendering/quality/shadows/shadow_atlas_size=2048

[input]

# Touch and mouse input for Android
"use_touchscreen=true"
"use_accelerometer=false"

[autoload]

GameManager="res://autoload/game_manager.gd"
LevelManager="res://autoload/level_manager.gd"
UpgradeManager="res://autoload/upgrade_manager.gd"
EconomyManager="res://autoload/economy_manager.gd"
SaveManager="res://autoload/save_manager.gd"
AudioManager="res://autoload/audio_manager.gd"

[physics]

common/physics_ticks_per_second=60

[android]

build/min_sdk=21
build/target_sdk=34
build/version_code=1
build/version_name="1.0.0"
build/package="com.neftegorsk.game"
build/keystore/debug="user://debug.keystore"
build/permissions=["android.permission.INTERNET", "android.permission.ACCESS_NETWORK_STATE", "android.permission.WAKE_LOCK"]
build/architectures=["arm64-v8a", "armeabi-v7a"]
build/export_presets="Android"

[input_map]

# Touch controls
touchscreen_tap={
"deadzone": 0.5,
"events": [Object(InputEventScreenTouch, "index": 0, "pressed": true)]
}

# Mouse click also works as tap
mouse_click={
"deadzone": 0.5,
"events": [Object(InputEventMouseButton, "button_index": 1, "pressed": true)]
}